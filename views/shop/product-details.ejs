<%- include('../includes/head.ejs') %> <%- include('../includes/heading.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main class="py-12">
  <div class="container mx-auto">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-xl">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.9fr] lg:items-center">
        <img src="/<%= product.imageUrl %>" alt="<%= product.title %>" class="w-full rounded-3xl object-cover" />
        <div class="space-y-6">
          <div>
            <h2 class="text-3xl font-semibold text-slate-900"><%= product.title %></h2>
            <p class="mt-4 text-slate-600"><%= product.description %></p>
          </div>
          <div class="rounded-3xl bg-slate-50 p-6 text-slate-900">
            <span class="text-xl font-semibold">قیمت: </span>
            <span class="text-2xl font-bold text-slate-900"><%= product.price %> ريال</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
<%- include('../includes/end.ejs') %>
