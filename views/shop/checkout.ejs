<%- include('../includes/head.ejs') %> <%- include('../includes/heading.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main class="py-12">
  <div class="container mx-auto space-y-8">
    <ul class="space-y-6">
      <% products.forEach(p => { %>
        <li class="flex flex-col gap-4 rounded-3xl border border-slate-200 bg-white p-6 shadow-lg md:flex-row md:items-center md:justify-between">
          <div class="flex items-center gap-4">
            <img src="/<%= p.productId.imageUrl %>" alt="<%= p.productId.title %>" class="h-24 w-24 rounded-3xl object-cover" />
            <div>
              <h2 class="text-lg font-semibold text-slate-900"><%= p.productId.title %></h2>
              <p class="text-slate-600">تعداد: <%= p.quantity %></p>
            </div>
          </div>
        </li>
      <% }) %>
    </ul>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 text-center shadow-lg">
      <h3 class="text-xl font-semibold text-slate-900">مبلغ نهایی: <span class="text-sky-600"><%= totalSum %></span></h3>
    </div>

    <div class="text-center">
      <a class="inline-flex rounded-2xl bg-sky-600 px-6 py-3 text-white transition hover:bg-sky-700" href="/PaymentRequest">پرداخت</a>
    </div>
  </div>
</main>

<%- include('../includes/end.ejs') %>
