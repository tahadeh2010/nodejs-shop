<%- include('../includes/head.ejs') %> <%- include('../includes/heading.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main class="py-12">
  <div class="container mx-auto space-y-10">
    <% if(prods.length > 0) { %>
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        <% for(let product of prods) { %>
          <article class="rounded-3xl border border-slate-200 bg-white shadow-lg overflow-hidden">
            <img src="/<%= product.imageUrl %>" alt="<%= product.title %>" class="h-56 w-full object-cover" />
            <div class="p-6 space-y-4">
              <h2 class="text-xl font-semibold text-slate-900"><%= product.title %></h2>
              <p class="text-slate-600"><%= product.description %></p>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <span class="text-lg font-semibold text-slate-900"><%= product.price %></span>
                <div class="flex flex-wrap gap-3">
                  <a href="/products/<%= product._id %>" class="rounded-2xl border border-slate-300 bg-white px-4 py-2 text-slate-900 transition hover:bg-slate-100">جزئیات</a>
                  <% if(isAuthenticated) { %>
                    <%- include('../includes/add-to-cart.ejs',{product:product}) %>
                  <% } %>
                </div>
              </div>
            </div>
          </article>
        <% } %>
      </div>

      <%- include('../includes/pagination.ejs',{currentPage:currentPage,hasNextPage:hasNextPage,hasPreviousPage:hasPreviousPage,nextPage:nextPage,lastPage:lastPage})%>
    <% } else { %>
      <div class="rounded-3xl border border-slate-200 bg-white p-10 text-center shadow-lg">
        <h1 class="text-2xl font-semibold text-slate-900">محصولی یافت نشد ... !!!</h1>
      </div>
    <% } %>
  </div>
</main>

<%- include('../includes/end.ejs') %>
