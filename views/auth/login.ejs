<%- include('../includes/head.ejs') %>

<section class="min-h-screen bg-slate-50 py-16">
  <div class="container mx-auto">
    <div class="max-w-md mx-auto rounded-3xl bg-white p-8 shadow-xl">
      <div class="text-center mb-6">
        <h3 class="text-2xl font-semibold text-slate-900">ورود</h3>
        <p class="mt-2 text-slate-600">با حساب کاربری خود وارد شوید.</p>
      </div>

      <% if(errorMessage){ %>
        <div class="mb-4 rounded-2xl bg-red-100 p-4 text-red-700 border border-red-200"><%= errorMessage %></div>
      <% } %>
      <% if(successMessage[0]){ %>
        <div class="mb-4 rounded-2xl bg-emerald-100 p-4 text-emerald-700 border border-emerald-200"><%= successMessage[0] %></div>
      <% } %>

      <form action="/login" method="post" novalidate class="space-y-5">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div>
          <input
            name="email"
            type="email"
            id="email"
            class="w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-slate-500 focus:ring-2 focus:ring-slate-200"
            placeholder="نام کاربری یا ایمیل"
          />
        </div>

        <div>
          <input
            name="password"
            type="password"
            id="password"
            class="w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-slate-500 focus:ring-2 focus:ring-slate-200"
            placeholder="رمز عبور"
          />
        </div>

        <button class="w-full rounded-2xl bg-slate-900 px-4 py-3 text-white transition hover:bg-slate-700" type="submit">
          وارد شوید
        </button>
      </form>

      <div class="mt-6 text-center text-sm text-slate-600">
        <a class="text-sky-600 hover:underline" href="/reset">فراموشی رمز عبور</a>
      </div>
    </div>
  </div>
</section>

<%- include('../includes/end.ejs') %>
