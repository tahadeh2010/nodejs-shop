<%- include('../includes/head.ejs') %> <%- include('../includes/heading.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main class="py-12">
  <% if(prods.length > 0) { %>
  <div class="container mx-auto grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    <% for(let product of prods) { %>
    <article class="rounded-3xl border border-slate-200 bg-white shadow-lg overflow-hidden">
      <img src="/<%= product.imageUrl %>" alt="<%= product.title %>" class="h-56 w-full object-cover" />
      <div class="p-6">
        <h2 class="text-xl font-semibold text-slate-900"><%= product.title %></h2>
        <p class="mt-3 text-slate-600"><%= product.description %></p>
        <div class="mt-4 flex items-center justify-between gap-4">
          <span class="text-slate-900 font-semibold"><%= product.price %></span>
          <div class="flex flex-wrap items-center gap-2">
            <a href="/admin/edit-product/<%= product._id %>?edit=true" class="rounded-2xl bg-orange-500 px-4 py-2 text-white transition hover:bg-orange-600">ویرایش</a>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" value="<%= product._id %>" name="productId" />
            <button class="rounded-2xl bg-red-600 px-4 py-2 text-white transition hover:bg-red-700" onclick="deleteProduct(this)" type="button">حذف</button>
          </div>
        </div>
      </div>
    </article>
    <% } %>
  </div>
  <% } else { %>
  <div class="container mx-auto py-16 text-center">
    <h1 class="text-2xl font-semibold text-slate-900">محصولی یافت نشد ... !!!</h1>
  </div>
  <% } %>
</main>

<%- include('../includes/end.ejs') %>

